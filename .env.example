# CatSense AI - Environment Configuration Example
# Copy this to .env or add these to your deployment platform (Vercel/Render)

# --- Supabase Configuration ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- API Configuration ---
# Use http://localhost:5001 for local development
# Use your production URL (e.g., https://catsense-api.onrender.com) for deployment
VITE_API_URL=http://localhost:5001
